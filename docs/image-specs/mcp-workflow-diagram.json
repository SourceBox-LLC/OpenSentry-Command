{
  "diagram_spec": {
    "meta": {
      "spec_version": "1.0.0",
      "title": "MCP Agent Workflow",
      "description": "3-lane swimlane: AI AGENT (top) calls 7 MCP tools, COMMAND CENTER (middle) authenticates and dispatches each call, CLOUDNODE (bottom) produces physical data when needed."
    },
    "canvas": {
      "width": 1920,
      "height": 920,
      "unit": "px",
      "background_color": "#0a0a0f",
      "style_notes": "Flat dark UI. Three horizontal swimlanes with subtle dashed coloured rails. Numbered step circles on each lane. NOT photographic, NOT 3D, NOT illustrative."
    },
    "lanes": [
      {"label": "AI AGENT",       "color": "#a855f7", "rail_color": "rgba(168,85,247,0.2)", "y_pct": 0.18},
      {"label": "COMMAND CENTER", "color": "#22c55e", "rail_color": "rgba(34,197,94,0.2)",  "y_pct": 0.45},
      {"label": "CLOUDNODE",      "color": "#3b82f6", "rail_color": "rgba(59,130,246,0.2)", "y_pct": 0.72}
    ],
    "lane_label_letter_spacing": "0.13em",
    "lane_label_font_weight": 600,
    "steps": [
      {"x_pct": 0.10, "tool_name": "list_cameras",      "node_outcome": "metadata only",  "node_present": false},
      {"x_pct": 0.22, "tool_name": "view_camera",       "node_outcome": "JPEG snapshot",  "node_present": true},
      {"x_pct": 0.34, "tool_name": "watch_camera",      "node_outcome": "JPEG burst",     "node_present": true},
      {"x_pct": 0.47, "tool_name": "create_incident",   "node_outcome": "incident row",   "node_present": false},
      {"x_pct": 0.60, "tool_name": "attach_snapshot",   "node_outcome": "JPEG → DB",      "node_present": true},
      {"x_pct": 0.73, "tool_name": "attach_clip",       "node_outcome": "clip from cache","node_present": true},
      {"x_pct": 0.86, "tool_name": "finalize_incident", "node_outcome": "report body",    "node_present": false}
    ],
    "step_rendering": {
      "agent_lane_dot": "purple_filled_circle_with_white_step_number_inside_and_thin_purple_outer_ring",
      "command_center_lane_dot": "green_filled_circle_with_white_step_number_inside_and_thin_green_outer_ring",
      "cloudnode_lane_dot": "blue_filled_circle_with_white_check_mark_(✓)_— only_appears_when_node_present_is_true",
      "tool_name_label": "above_agent_dot_in_JetBrains_Mono_monospace_muted_grey",
      "node_outcome_label": "below_cloudnode_lane_in_Inter_sans-serif_muted_grey_— always_shown_even_when_node_dot_absent",
      "vertical_connecting_lines": "thin_dashed_white_5%_opacity_running_top_to_bottom_through_each_step_column"
    },
    "legend_panel": {
      "position": "bottom_full_width",
      "background": "#161620",
      "border_color": "rgba(255,255,255,0.10)",
      "border_radius": 8,
      "items": [
        {"bullet_color": "#22c55e", "bold_label": "READ",   "trailing_text": "metadata only · list / get"},
        {"bullet_color": "#f59e0b", "bold_label": "VISUAL", "trailing_text": "returns images the model can see"},
        {"bullet_color": "#a855f7", "bold_label": "WRITE",  "trailing_text": "creates or updates state"}
      ]
    },
    "constraints": {
      "layout_lock": true,
      "exact_text": [
        "AI AGENT", "COMMAND CENTER", "CLOUDNODE",
        "list_cameras", "view_camera", "watch_camera", "create_incident",
        "attach_snapshot", "attach_clip", "finalize_incident",
        "metadata only", "JPEG snapshot", "JPEG burst", "incident row",
        "JPEG → DB", "clip from cache", "report body",
        "READ", "metadata only · list / get",
        "VISUAL", "returns images the model can see",
        "WRITE", "creates or updates state"
      ],
      "do_not_change_text": true,
      "do_not_misspell_anything": true,
      "rendering_notes": "Premium technical-doc style. Crisp typography. Tool names in monospace, lane labels in spaced caps. Numbered dots are EXACTLY 1-7 in the agent and CC lanes; the CLOUDNODE lane shows ONLY check-mark dots and only at columns 2, 3, 5, 6 (view_camera, watch_camera, attach_snapshot, attach_clip). NOT photographic. Aspect ratio 16:9."
    }
  }
}
