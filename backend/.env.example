# Backend Environment Variables

# Clerk Authentication (required)
# Get these from https://clerk.com/ dashboard
CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_secret_key_here
CLERK_JWKS_URL=
CLERK_WEBHOOK_SECRET=

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_URL=sqlite:///./opensentry.db

# OpenSentry Security Secret (for camera node authentication)
OPENSENTRY_SECRET=your_secret_key_here

# Tigris Object Storage (Fly.io)
# Get these from: flyctl storage create -n opensentry-cameras
AWS_ENDPOINT_URL_S3=https://fly.storage.tigris.dev
AWS_ACCESS_KEY_ID=tid_your_access_key_here
AWS_SECRET_ACCESS_KEY=tsec_your_secret_key_here
AWS_REGION=auto
BUCKET_NAME=opensentry-cameras

# Stream URL expiry (seconds)
STREAM_URL_EXPIRY_SECONDS=300
UPLOAD_URL_EXPIRY_SECONDS=300
UPLOAD_TIMEOUT_MINUTES=10

# Session timeout (minutes)
SESSION_TIMEOUT=30