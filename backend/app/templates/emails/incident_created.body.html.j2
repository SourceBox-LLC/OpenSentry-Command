<h2 style="margin:0 0 16px;font-size:20px;font-weight:600;color:#111;line-height:1.3;">
  {{ notification.title | e }}
</h2>

<p style="margin:0 0 20px;font-size:15px;line-height:1.6;color:#374151;">
  {{ notification.body | e }}
</p>

{% if notification.camera_id %}
<table role="presentation" cellpadding="0" cellspacing="0" border="0" style="margin:0 0 20px;background:#f9fafb;border-radius:6px;width:100%;">
  <tr>
    <td style="padding:12px 14px;font-size:13px;color:#6b7280;">
      Related camera
    </td>
    <td style="padding:12px 14px;font-size:13px;color:#111;font-family:ui-monospace,Menlo,Consolas,monospace;text-align:right;">
      {{ notification.camera_id | e }}
    </td>
  </tr>
</table>
{% endif %}

<p style="margin:0 0 24px;font-size:14px;line-height:1.6;color:#6b7280;">
  An AI agent connected to your Command Center created this incident
  report after observing something noteworthy. Review the report,
  attached evidence (snapshots/clips), and the agent's reasoning.
</p>

<table role="presentation" cellpadding="0" cellspacing="0" border="0">
  <tr>
    <td style="background:#22c55e;border-radius:6px;">
      <a href="{{ dashboard_url }}{{ notification.link or '/incidents' }}"
         style="display:inline-block;padding:10px 18px;font-size:14px;font-weight:600;color:#0a0a0f;text-decoration:none;">
        Open incident →
      </a>
    </td>
  </tr>
</table>
